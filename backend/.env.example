# Base de données
DATABASE_URL=postgresql://user:password@postgres:5432/boutiki?sslmode=disable
DATABASE_SSL=false

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Serveur
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Sécurité
BCRYPT_ROUNDS=12

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (optional — dev logs to console if RESEND_API_KEY unset)
# RESEND_API_KEY=
# EMAIL_FROM=BoutiqueKi <onboarding@resend.dev>

# Stripe (optional — card payment is disabled until these are set)
# Test keys: https://dashboard.stripe.com (mode Test) → Developers → API keys
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...   (from `stripe listen`)
