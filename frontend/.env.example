# URL de l'API backend.
# En dev, laissez vide : Vite proxy /api et /uploads vers http://localhost:3000.
# En prod (Vercel), mettez l'URL complète de l'API, ex: https://api.boutiqueki.com/api
VITE_API_URL=

# Google OAuth — Client ID (https://console.cloud.google.com/apis/credentials)
VITE_GOOGLE_CLIENT_ID=
